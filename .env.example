# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexuspay
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=change-me-in-production-must-be-at-least-256-bits-long-secret-key

# Encryption — base64-encoded 32-byte key for AES-256-GCM (provider credentials).
# REQUIRED to store provider credentials. Generate your own: openssl rand -base64 32
# (the value below is a dev-only example — DO NOT use in production)
ENCRYPTION_KEY=rKABRnG8EvJW23YLsrpQppWf+2KnESrKg24mPHwsqiM=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# App
APP_BASE_URL=http://localhost:3001
PAY_BASE_URL=http://localhost:5173

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Square (optional)
SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_ID=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=
